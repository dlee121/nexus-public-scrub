# MCP server secrets for .mcp.json
#
# Copy this file to .mcp-secrets.env (gitignored) and fill in the real
# values. scripts/launch_nexus.sh sources .mcp-secrets.env if present
# so the Orchestrator daemon — and every Claude Code instance it spawns —
# inherits these in env. .mcp.json references them via ${VAR} syntax.
#
# For interactive `claude` sessions launched outside launch_nexus.sh,
# either source this file manually before invocation or add the exports
# to your shell rc (~/.zshrc).
#
# All three values below were leaked in prior commits and must be
# rotated when populating .mcp-secrets.env for the first time:
#   - SLACK_BOT_TOKEN — committed in c83ed35; rotate at api.slack.com/apps
#   - CLICKHOUSE_PASSWORD — committed in c83ed35; rotate in ClickHouse Cloud console
#   - GITHUB_PERSONAL_ACCESS_TOKEN — last leaked Apr 27; revoke at github.com/settings/tokens
#                                    only needed if you re-enable the github MCP server entry
#
# DO NOT COMMIT THE POPULATED .mcp-secrets.env FILE.

CLICKHOUSE_PASSWORD=
SLACK_BOT_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=

# Cloudflare Access service token for the forge.[company-domain] application.
# Required for `forge transcript` (and any other forge CLI subcommand)
# from off-EC2 hosts — CF Access blocks anonymous traffic at the edge
# before X-Forge-Token can be inspected, so the CLI 403s without these.
# Generate at: Cloudflare Zero Trust → Access → Service Auth.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
