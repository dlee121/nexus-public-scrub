{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ForgeWorkerReadOwnSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-west-2:*:secret:/forge-worker/prod/*"
      ]
    },
    {
      "Sid": "ForgeWorkerListSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:ListSecrets"
      ],
      "Resource": "*"
    }
  ]
}
